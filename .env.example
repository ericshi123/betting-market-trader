# Anthropic API key (required for scan / edges commands)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Kalshi API credentials (required for live-bet, live-status, kill-switch)
# ---------------------------------------------------------------------------
# Where to get these:
#   1. Go to https://kalshi.com and create an account
#   2. Navigate to Account → Settings → API
#   3. Generate an API key — this gives you a Key ID and prompts you to
#      download or generate an RSA private key (PEM format)
#   4. Save the private key file to a secure location (e.g. ~/.kalshi/private_key.pem)
#      and set KALSHI_PRIVATE_KEY_PATH to that path. Never commit the key file.
#
# These are only needed for Phase 5 live trading. Phases 1–4 work without them.

# Your Kalshi API Key ID (UUID from the API management page)
KALSHI_API_KEY_ID=

# Absolute path to your RSA private key PEM file (e.g. /Users/you/.kalshi/private_key.pem)
KALSHI_PRIVATE_KEY_PATH=
