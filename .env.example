# Anthropic API key (required for scan / edges commands)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Polymarket CLOB credentials (required for live-bet, live-status, kill-switch)
# ---------------------------------------------------------------------------
# Where to get these:
#   1. Go to https://polymarket.com and connect your wallet
#   2. Navigate to Account → API Keys (or Settings → Developer)
#   3. Generate a new API key — this gives you POLY_API_KEY, POLY_API_SECRET,
#      and POLY_PASSPHRASE
#   4. POLY_PRIVATE_KEY is your wallet's Ethereum private key (the wallet you
#      use on Polymarket, funded with USDC on Polygon). Keep this secret.
#      Never commit it to version control.
#
# These are only needed for Phase 5 live trading. Phases 1–4 work without them.

# Your Polymarket API key (from the API key management page)
POLY_API_KEY=

# Your Polymarket API secret (from the API key management page)
POLY_API_SECRET=

# Your Polymarket API passphrase (from the API key management page)
POLY_PASSPHRASE=

# Your wallet private key (hex string, 0x-prefixed or raw 64-char hex)
# This is the private key of the Polygon wallet connected to your Polymarket account
POLY_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# Optional: override API endpoints (useful for testing against a staging env)
# ---------------------------------------------------------------------------
# CLOB_HOST=https://clob.polymarket.com
# GAMMA_HOST=https://gamma-api.polymarket.com
